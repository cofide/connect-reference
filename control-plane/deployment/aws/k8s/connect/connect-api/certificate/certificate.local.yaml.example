# Cluster-specific patch for the Connect API cert-manager Certificate.
# Copy to certificate.local.yaml and fill in your values. This file is gitignored.

apiVersion: cert-manager.io/v1
kind: Certificate
metadata:
  name: connect-tls
  namespace: connect
spec:
  dnsNames:
    - connect.example.cofide.dev
    - connect-agent.example.cofide.dev
    - xds.example.cofide.dev
