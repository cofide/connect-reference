# Cluster-specific patch for the cert-manager ClusterIssuer.
# Copy to cluster-issuer.local.yaml and fill in your values. This file is gitignored.

apiVersion: cert-manager.io/v1
kind: ClusterIssuer
metadata:
  name: letsencrypt
spec:
  acme:
    # Replace with your email address for Let's Encrypt account registration.
    email: admin@example.com
    solvers:
      - dns01:
          route53:
            # Replace with the AWS region and ID of the Route53 hosted zone managed
            # by the cert-manager IAM role (configured in infra/stack/base/eks-cluster/controllers/cert-manager/).
            region: eu-west-2
            hostedZoneID: Z0000000000000000000
