# Optional overrides for the aws-load-balancer-controller unit. Copy to common.local.hcl
# and uncomment the values you want to change. All fields are optional — omitting a field
# uses the default defined in terragrunt.hcl.

locals {
  # Optional: deploy against an existing cluster instead of the cluster unit output.
  # cluster_name = "my-cluster"

  # Optional: use IRSA instead of EKS Pod Identity.
  # Requires enable_irsa = true in the cluster unit and oidc_provider_arn to be set.
  # iam_mode          = "irsa"
  # oidc_provider_arn = "arn:aws:iam::123456789012:oidc-provider/oidc.eks.eu-west-1.amazonaws.com/id/ABCDEF1234567890"

  # Optional: override IAM resource names.
  # role_name   = "my-alb-controller-role"
  # policy_name = "my-alb-controller-policy"

  # Optional: override the Kubernetes namespace and service account name.
  # These must match the values used when deploying the controller via Helm.
  # namespace            = "kube-system"
  # service_account_name = "aws-load-balancer-controller"
}
